# ScreenBuddy desktop — build-time env (Vite inlines these at `vite build`).
# Copy to `.env` for local dev. The release/stapled build MUST be built with
# VITE_CU_BACKEND_URL pointing at prod, or it will ship pointed at localhost.

# ScreenBuddy backend (auth + runs/templates/telemetry). Single var points the
# whole app at one backend. Prod: https://ai-screen-buddy-backend.pageapp.net
# Local dev: http://localhost:8000
VITE_CU_BACKEND_URL=https://ai-screen-buddy-backend.pageapp.net
